{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account details and trading balance",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "virtualBalance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "virtualBalance"]
    },
    "Trade": {
      "title": "Trade Execution",
      "description": "Historical and active trades",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["long", "short"] },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "amount": { "type": "number" },
        "leverage": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "pnl": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "closedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "entryPrice", "amount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Sub-collection of trades for each user"
    }
  }
}
